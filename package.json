{
  "name": "nexus",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint:js": "eslint .",
    "lint:styles": "stylelint \"src/**/*.{css,scss}\" --allow-empty-input",
    "lint:html": "html-validate \"*.html\" \"src/**/*.html\"",
    "lint": "npm run lint:js && npm run lint:styles && npm run lint:html",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "npm run format:check && npm run lint && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "html-validate": "^11.5.6",
    "prettier": "^3.9.5",
    "sass": "^1.101.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "vite": "^8.1.1"
  }
}
